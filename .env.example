# Copy this file to .env and fill in real values.
# .env should be in .gitignore — never commit real secrets.
#
# IMPORTANT: Docker Compose's .env parser expects plain KEY=VALUE lines.
# Do NOT prefix lines with `export` (that's bash syntax for a sourced
# shell script, not what Compose reads) — a line like
# `export HATCHECK_RATE_ADMIN_BURST=10` will not be parsed as the
# HATCHECK_RATE_ADMIN_BURST variable and the value will silently not apply.

# HMAC-SHA256 key used to sign every capability. Anyone who has this key
# can forge valid capabilities, so treat it like a root credential.
# Generate one with: openssl rand -base64 32
HATCHECK_SIGNING_KEY=

# Optional. Shared secret that grants PermAdmin without a signed
# capability — used for first-time bootstrap (issuing the very first admin
# capability). Leave unset once real admin capabilities exist; an unset
# value disables the bootstrap path entirely (see CapabilityMiddleware.Protect).
HATCHECK_BOOTSTRAP_TOKEN=

# From your Stytch dashboard (https://stytch.com) — Consumer project.
STYTCH_PROJECT_ID=
STYTCH_SECRET=

# Where Stytch redirects after a magic-link click. Must exactly match what's
# configured in the Stytch dashboard for this project. For local docker
# compose testing this is usually http://localhost:8090/auth/authenticate;
# update to your real domain in production.
STYTCH_REDIRECT_URL=http://localhost:8090/auth/authenticate

# ── Operational tuning (all optional — Config.go defaults apply if blank) ──

# How long an issued capability remains valid. Go duration format.
# Default: 8760h (365 days)
HATCHECK_CAPABILITY_EXPIRY=

# Read-route rate limit (/fetch, /list, /query, /namespaces, /names,
# /relations, /tags). Defaults: 1s interval, burst of 10.
HATCHECK_RATE_READ_INTERVAL=
HATCHECK_RATE_READ_BURST=

# Write-route rate limit (/stash, /collection, /relation, /name).
# Defaults: 5s interval, burst of 4.
HATCHECK_RATE_WRITE_INTERVAL=
HATCHECK_RATE_WRITE_BURST=

# Admin-route rate limit (/export, /import, /capability,
# /capability/revoke, /capabilities, /principals). Defaults: 30s interval,
# burst of 2 — tuned for infrequent one-off admin actions, NOT for actively
# browsing the admin UI, which fires several of these per page load/tab
# switch. If the admin UI is tripping 429s during normal use, raise these,
# e.g.:
#   HATCHECK_RATE_ADMIN_INTERVAL=5s
#   HATCHECK_RATE_ADMIN_BURST=10
HATCHECK_RATE_ADMIN_INTERVAL=
HATCHECK_RATE_ADMIN_BURST=
