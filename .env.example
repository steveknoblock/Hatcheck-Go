# Copy this file to .env and fill in real values.
# .env should be in .gitignore — never commit real secrets.

# HMAC-SHA256 key used to sign every capability. Anyone who has this key
# can forge valid capabilities, so treat it like a root credential.
# Generate one with: openssl rand -base64 32
HATCHECK_SIGNING_KEY=

# Optional. Shared secret that grants PermAdmin without a signed
# capability — used for first-time bootstrap (issuing the very first admin
# capability). Leave unset once real admin capabilities exist; an unset
# value disables the bootstrap path entirely (see CapabilityMiddleware.Protect).
HATCHECK_BOOTSTRAP_TOKEN=

# From your Stytch dashboard (https://stytch.com) — Consumer project.
STYTCH_PROJECT_ID=
STYTCH_SECRET=

# Where Stytch redirects after a magic-link click. Must exactly match what's
# configured in the Stytch dashboard for this project. For local docker
# compose testing this is usually http://localhost:8090/auth/authenticate;
# update to your real domain in production.
STYTCH_REDIRECT_URL=http://localhost:8090/auth/authenticate
